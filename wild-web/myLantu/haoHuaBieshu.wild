          "axis": "z",
          "limit": [0, 90]
        }
      ]
    },
    "scripts": [
      {
        "on_click": {
          "condition": "event.target == 'front_door'",
          "actions": [
            { "type": "toggle_hinge", "target": "front_door" },
            { "type": "play_sound", "sound": "wooden_door_open" }
          ]
        }
      },
      {
        "on_click": {
          "condition": "event.target == 'balcony_door'",
          "actions": [
            { "type": "toggle_hinge", "target": "balcony_door" },
            { "type": "play_sound", "sound": "glass_door_open" }
          ]
        }
      }
    ]
